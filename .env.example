GEMINI_API_KEY=tu_clave_aqui_para_activar_el_motor_inteligente

# --- web-server (opcional) ---
# Interfaz a la que bindea el backend. Default: 127.0.0.1 (solo loopback, no LAN).
# Poné 0.0.0.0 SOLO si querés exposición de red y ponés tu propia auth delante.
# WEB_SERVER_HOST=127.0.0.1
# Orígenes CORS permitidos (coma-separados). Default: dev server de Angular. Nunca '*'.
# WEB_SERVER_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Token local: si se setea, las rutas POST (ask/approvals) exigen el header
# x-csos-token con este valor. Útil para volumen compartido / multi-usuario.
# WEB_SERVER_TOKEN=
